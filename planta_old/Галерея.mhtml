.5, transparent), to(rgba(255, 255, 255, 0.3))); }

.ei-slider-thumbs li:hover img { opacity: 1; bottom: 13px; }

@media screen and (max-width: 830px) {
  .ei-title { position: absolute; right: 0px; margin-right: 0px; width: 100=
